{
  "thinkingLevel": "xhigh",
  "theme": "dark",
  "enableInstallTelemetry": false,
  "compaction": {
    "mode": "auto",
    "threshold": 0.75,
    "minMessages": 20
  },
  "messageDelivery": {
    "steeringMode": "one-at-a-time",
    "followUpMode": "one-at-a-time"
  },
  "transport": "auto",
  "cacheRetention": "long",
  "ui": {
    "showToolOutput": true,
    "compactToolOutput": false,
    "showThinking": true
  },
  "editor": {
    "multiLineSubmit": "shift-enter"
  }
}
